    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find mm_bringup)/meshes/right_front_wheel_link_c.STL" />
      </geometry>
    </collision>
  </link>
  <joint
