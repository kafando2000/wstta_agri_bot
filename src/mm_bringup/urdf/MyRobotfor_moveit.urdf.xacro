<?xml version="1.0" ?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="WSTTA_ROBOT">
  <!--<xacro:include filename="file://$(find mm_bringup)/urdf/MyRobot_gz.gazebo" />-->
  <!--<xacro:include filename="$(find mm_bringup)/urdf/MyRobot.ros2control" />-->
  <xacro:include filename="$(find mm_bringup)/urdf/materials.xacro" />
  <xacro:include filename="$(find mm_bringup)/urdf/arm.xacro" />
  <xacro:include filename="$(find mm_bringup)/urdf/lidar.xacro" />
  <xacro:include filename="$(find mm_bringup)/urdf/imu.xacro" />
  <xacro:include filename="$(find mm_bringup)/urdf/camera.xacro" />
  <xacro:include filename="$(find mm_bringup)/urdf/ultrasonic.xacro" />
  <!--base foot print link for odometry-->
  <link name="base_footprint" />
  <joint name="base_footprint_base_link" type="fixed">
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <parent
      link="base_footprint" />
    <child
      link="base_link" />
  </joint>
  <link
    name="base_link">
    <inertial>
      <origin
        xyz="0.0009926 0.0019362 0.044759"
        rpy="0 0 0" />
      <mass
        value="1.742" />
      <inertia
        ixx="0.018183"
        ixy="-2.9255E-05"
        ixz="4.4241E-05"
        iyy="0.027172"
        iyz="-5.1965E-05"
        izz="0.043318" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find mm_bringup)/meshes/base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.113725490196078 0.207843137254902 0.349019607843137 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find mm_bringup)/meshes/base_link_c.STL" />
      </geometry>
    </collision>
  </link>
  <link
    name="left_front_wheel_link">
    <inertial>
      <origin
        xyz="1.9358E-06 0.01449 1.8677E-06"
        rpy="0 0 0" />
      <mass
        value="0.11904" />
      <inertia
        ixx="0.00015193"
        ixy="6.9518E-09"
        ixz="1.2783E-09"
        iyy="0.00023025"
        iyz="6.731E-09"
        izz="0.00015193" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find mm_bringup)/meshes/left_front_wheel_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.29804 0.29804 0.29804 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find mm_bringup)/meshes/left_rear_wheel_link_c.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="left_front_wheel_joint"
    type="continuous">
    <origin
      xyz="0.10969 0.16824 0.0165"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="left_front_wheel_link" />
    <axis
      xyz="0 1 0" />
    <dynamics
      damping="0.5"
      friction="0.1" />
  </joint>
  <link
    name="left_rear_wheel_link">
    <inertial>
      <origin
        xyz="-8.6382E-05 0.01449 4.5072E-05"
        rpy="0 0 0" />
      <mass
        value="0.11904" />
      <inertia
        ixx="0.00015193"
        ixy="8.59E-09"
        ixz="-1.0577E-09"
        iyy="0.00023025"
        iyz="-4.4616E-09"
        izz="0.00015193" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find mm_bringup)/meshes/left_rear_wheel_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.29804 0.29804 0.29804 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find mm_bringup)/meshes/left_rear_wheel_link_c.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="left_rear_wheel_joint"
    type="continuous">
    <origin
      xyz="-0.11022 0.16824 0.016454"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="left_rear_wheel_link" />
    <axis
      xyz="0 1 0" />
    <dynamics
      damping="0.5"
      friction="0.1" />
    <mimic
      joint="left_front_wheel_joint"
      multiplier="1"
      offset="0" />
  </joint>
