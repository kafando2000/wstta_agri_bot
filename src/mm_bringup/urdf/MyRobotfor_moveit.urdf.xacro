      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="right_front_wheel_link" />
    <axis
      xyz="0 1 0" />
    <dynamics
      damping="0.5"
      friction="0.1" />
  </joint>
  <link
    name="right_rear_wheel_link">
    <inertial>
      <origin
        xyz="-9.18065809774049E-05 -0.0144898421944957 -3.26599531583205E-05"
        rpy="0 0 0" />
      <mass
        value="0.119038159969982" />
      <inertia
        ixx="0.000151931672363267"
        ixy="-9.09099150002439E-09"
        ixz="8.20737861022572E-10"
        iyy="0.000230248991142072"
        iyz="-3.25295725432534E-09"
        izz="0.000151929718320073" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find mm_bringup)/meshes/right_rear_wheel_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.298039215686275 0.298039215686275 0.298039215686275 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find mm_bringup)/meshes/right_front_wheel_link_c.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="right_rear_wheel_joint"
    type="continuous">
    <origin
      xyz="-0.11022 -0.16776 0.016534"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="right_rear_wheel_link" />
    <axis
      xyz="0 1 0" />
    <dynamics
      damping="0.5"
      friction="0.1" />
    <mimic
      joint="right_front_wheel_joint"
      multiplier="1"
      offset="0" />
  </joint>

  <link
    name="recipient_Link">
    <inertial>
      <origin
        xyz="-2.22044604925031E-16 2.22044604925031E-16 0.0267296895245414"
        rpy="0 0 0" />
      <mass
        value="0.217690400735568" />
      <inertia
        ixx="0.000695386873840761"
        ixy="-2.57498015965307E-19"
        ixz="4.16912900503068E-19"
        iyy="0.00069538687384076"
        iyz="-1.0905491269373E-19"
        izz="0.000866872476711265" />
    </inertial>
    <visual>
      <origin
