<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="Untitled">
    <Sequence>
      <PublishResult topic_name="number" generated_number="{generated_number}"/>
      <Fallback>
        <CheckNumber1 check_value="1" generated_number="{generated_number}"/>
        <Fallback>
          <CheckNumber2 check_value="10"
                        generated_number="{generated_number}"/>
          <ForceSuccess>
            <CheckNumber3 check_value="30"
                          generated_number="{generated_number}"/>
          </ForceSuccess>
        </Fallback>
      </Fallback>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="CheckNumber1"
            editable="true">
      <input_port name="check_value"
                  default="1"
                  type="double"/>
      <output_port name="generated_number"
                   type="double"/>
    </Action>
    <Action ID="CheckNumber2"
            editable="true">
      <input_port name="check_value"
                  default="1"
                  type="double"/>
      <output_port name="generated_number"
                   type="double"/>
    </Action>
    <Action ID="CheckNumber3"
            editable="true">
      <input_port name="check_value"
                  default="1"
                  type="double"/>
      <output_port name="generated_number"
                   type="double"/>
    </Action>
    <Action ID="PublishResult"
            editable="true">
      <input_port name="topic_name"
                  type="std::string"/>
      <input_port name="generated_number"
                  type="double"/>
    </Action>
  </TreeNodesModel>

</root>
